{
  "expo": {
    "name": "SUSHITAP",
    "slug": "sushitap",
    "version": "1.0.907",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFF6EE"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "dev.d1ito.sushitap"
    },
    "android": {
      "package": "dev.d1ito.sushitap",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFF6EE"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font",
      "expo-localization"
    ],
    "extra": {
      "eas": {
        "projectId": "f10e639d-a66b-4999-bfdf-5cb998765e7d"
      }
    }
  }
}
